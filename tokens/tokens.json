{
  "$schema": "./tokens.schema.json",
  "_meta": {
    "source": "Derived from 3iq.io Webflow stylesheet, verified April 2026.",
    "companion_files": ["tokens.yaml", "tokens.css"],
    "update_policy": "Edit tokens.yaml first, then mirror into .json and .css."
  },

  "brand": {
    "name": "3iQ Corp",
    "short": "3iQ",
    "tagline": "Forging new paths in alternative investing.",
    "positioning": "Digital asset manager pioneering institutional-grade digital asset investments for forward-thinking institutions.",
    "founded": 2012,
    "hq": "161 Bay Street, Suite 2700, Toronto, Ontario, Canada M5J 2S1",
    "parent": "Monex Group (Coincheck Group as of 2026)"
  },

  "color": {
    "swatch": {
      "dark":            "#080E23",
      "dark_secondary":  "#4C3D32",
      "light":           "#FDFCFA",
      "light_secondary": "#F4ECE5",
      "light_tertiary":  "#F8F7F5",
      "neutral":         "#DDDDDD",
      "transparent":     "#FFFFFF00",
      "brand":           "#D6D5BF",
      "brand_2":         "#C9D7D7",
      "brand_3":         "#EAE9DD",
      "brand_4":         "#B8C6C6",
      "green":           "#4C9478",
      "yellow":          "#EDC576",
      "orange":          "#E6704E",
      "alert_negative":  "#DA3B3B",
      "alert_positive":  "#4C9478"
    },
    "role": {
      "dark": {
        "bg":         "#080E23",
        "surface":    "#4C3D32",
        "text":       "#FDFCFA",
        "text_muted": "#D6D5BF",
        "border":     "#FDFCFA",
        "cta_bg":     "transparent",
        "cta_text":   "#080E23",
        "accent":     "#EDC576",
        "rule":       "#EDC576"
      },
      "light": {
        "bg":         "#FDFCFA",
        "surface":    "#F8F7F5",
        "text":       "#080E23",
        "text_muted": "#4C3D32",
        "border":     "#080E23",
        "cta_bg":     "#D6D5BF",
        "cta_text":   "#080E23",
        "accent":     "#EDC576",
        "rule":       "#080E23"
      }
    },
    "fund_theme": {
      "etf": {
        "label": "ETF / Forge",
        "gradient_top":    "#080E23",
        "gradient_bottom": "#4C3D32",
        "accent":          "#EDC576"
      },
      "cef": {
        "label": "CEF / Growth",
        "gradient_top":    "#1E3239",
        "gradient_bottom": "#02393C",
        "accent":          "#4C9478"
      },
      "multi_crypto": {
        "label": "Multi-crypto / Warmth",
        "gradient_top":    "#1C0E1D",
        "gradient_bottom": "#3A1717",
        "accent":          "#E6704E"
      }
    }
  },

  "typography": {
    "primary": {
      "family": "Neue Haas Grotesk Display, Inter, -apple-system, BlinkMacSystemFont, sans-serif",
      "source": "Adobe Typekit kit: iwl6vrh",
      "fallback_web":   "Inter, -apple-system, Segoe UI, sans-serif",
      "fallback_email": "Arial, Helvetica, sans-serif",
      "fallback_pptx":  "Arial",
      "weights": { "light": 300, "regular": 400, "medium": 500, "semibold": 600 }
    },
    "secondary": {
      "family": "Denton, Palatino Linotype, Georgia, serif",
      "source": "Self-hosted on Webflow CDN",
      "fallback_web":   "Palatino Linotype, Georgia, serif",
      "fallback_email": "Georgia, Times New Roman, serif",
      "fallback_pptx":  "Times New Roman",
      "weights": { "light": 300 }
    },
    "local": {
      "serif_variable": "assets/fonts/DentonVariableTest-VF.otf",
      "sans_variable":  "assets/fonts/FunnelSans-VariableFont_wght.ttf"
    },
    "scale": {
      "display":    "7rem",
      "h1":         "5rem",
      "h2":         "4rem",
      "h3":         "3rem",
      "h4":         "2.5rem",
      "h5":         "2rem",
      "h6":         "1.5rem",
      "text_large": "1.25rem",
      "text_main":  "1rem",
      "text_small": "0.875rem"
    },
    "role_to_family": {
      "display": "secondary", "h1": "secondary", "h2": "secondary",
      "h3": "secondary", "h4": "secondary", "h5": "secondary",
      "h6": "primary",
      "text_large": "primary", "text_main": "primary", "text_small": "primary"
    },
    "line_height":    { "tight": "1em", "snug": "1.1em", "normal": "1.25em", "relaxed": "1.5em" },
    "letter_spacing": { "normal": "0em", "heading": "0.01em", "wide": "0.04em" },
    "weight_defaults": { "heading": 300, "body": 500, "ui": 500, "strong": 600 }
  },

  "size": {
    "0": "0rem", "0-125": "0.125rem", "0-25": "0.25rem", "0-5": "0.5rem",
    "0-75": "0.75rem", "1": "1rem", "1-25": "1.25rem", "1-5": "1.5rem",
    "2": "2rem", "2-5": "2.5rem", "3": "3rem", "3-5": "3.5rem",
    "4": "4rem", "5": "5rem", "6": "6rem", "7": "7rem",
    "8": "8rem", "10": "10rem", "12": "12rem", "15": "15rem"
  },

  "padding": {
    "vertical": {
      "none": "0rem", "x_small": "2.5rem", "small": "5rem",
      "main": "7rem", "large": "10rem", "x_large": "15rem"
    },
    "horizontal": { "small": "2.5rem", "main": "5rem" }
  },

  "radius": {
    "x_small": "0.25rem", "small": "0.375rem",
    "main":    "1rem",    "round": "100vw"
  },

  "border_width": { "main": "1px", "large": "2px" },

  "gradient": {
    "forge":            "linear-gradient(180deg, #080E23, #4C3D32)",
    "growth":           "linear-gradient(180deg, #1E3239, #02393C)",
    "warmth":           "linear-gradient(180deg, #1C0E1D, #3A1717)",
    "card_sand":        "linear-gradient(180deg, #D6D5BF, #F8F7F5)",
    "card_sky":         "linear-gradient(180deg, #C9D7D7, #F4ECE5)",
    "card_cream":       "linear-gradient(180deg, #EAE9DD, #FDFCFA)",
    "card_sage":        "linear-gradient(180deg, #B8C6C6, #F8F7F5)",
    "button_dark":      "linear-gradient(to right, #FDFCFA 15%, #D6D5BF 100%)",
    "dark_fade_right":  "linear-gradient(90deg, #080E23, #080E231A 65%)"
  },

  "logo": {
    "primary": "assets/logos/3iq_logo.svg",
    "viewbox": "0 0 96 30",
    "clearspace": "Minimum clearspace around the logo equals the height of the 'Q'.",
    "min_width_px": 80,
    "favicon": "https://cdn.prod.website-files.com/66e3ac70d4e9ed3fc8e8ed73/671665da9e6883bbe185082a_3iq_favicon.png",
    "webclip": "https://cdn.prod.website-files.com/66e3ac70d4e9ed3fc8e8ed73/671665ddd2780d4c95ae2533_3iq_webclip.png"
  },

  "voice": {
    "tone": "Confident, precise, institutional. Uses measured language ('pioneering', 'forging', 'institutional-grade', 'regulated'). Avoids hype. Treats digital assets as a legitimate asset class for traditional allocators.",
    "signature_phrases": [
      "Forging new paths in alternative investing.",
      "Institutional-grade digital asset investments.",
      "Pioneering digital asset investment management since 2012.",
      "Regulated, secure, institutional-grade."
    ],
    "do": [
      "Lead with the fact or milestone; context follows.",
      "Name specific regulators, exchanges, and instruments.",
      "Cite firsts (e.g. 'world's first ETH staking ETF', 'first regulated DAIFM in Canada').",
      "Use numbers with units (USD, bps, AUM, jurisdiction).",
      "Prefer 'digital assets' over 'crypto' in institutional contexts."
    ],
    "dont": [
      "Emojis in marketing copy.",
      "Crypto-native slang (HODL, WAGMI, moon, ape, etc.).",
      "Exclamation marks.",
      "Hype adjectives (revolutionary, game-changing, disruptive, insane).",
      "All-caps headlines (except short eyebrows)."
    ]
  },

  "products": {
    "categories": [
      { "name": "Digital Asset Solutions", "url": "/digital-asset-investment-solutions" },
      { "name": "Active Investment Solutions", "url": "/actively-managed-solutions" },
      { "name": "Yield Solutions", "url": "/yield-solutions" }
    ],
    "fund_structures": {
      "etf":   "Exchange-Traded Fund",
      "cef":   "Closed-End Fund",
      "etp":   "Exchange-Traded Product",
      "hedge": "Hedge Fund / QMAP"
    },
    "known_firsts": [
      "2017: First regulated Digital Asset Investment Fund Manager in Canada",
      "2020: North America's first major exchange-listed Bitcoin and Ether Funds",
      "2021: Middle East's first exchange-listed Bitcoin-based fund on Nasdaq Dubai",
      "2023: World's first ETH staking ETF",
      "2025: One of the first Solana Staking ETFs and XRP ETFs",
      "2026: First Canadian commercial bank-backed actively managed ETF"
    ]
  },

  "social": {
    "twitter":  "https://x.com/3iQ_corp",
    "linkedin": "https://www.linkedin.com/company/3iq-corp/",
    "youtube":  "https://www.youtube.com/channel/UCx3LCjlvxRkq5Syq99liUbw",
    "blog":     "https://blog.3iq.io"
  },

  "contact": {
    "phone":   "+1 (416) 639-2130",
    "email":   "[EMAIL]",
    "website": "https://3iq.io"
  },

  "disclaimer": {
    "standard": "This communication is for informational purposes only and does not constitute investment advice or an offer to sell or solicitation to buy any security.",
    "footer":   "© 2024 3iQ Corp. All rights reserved. Investing in digital assets involves risks. Please read all offering documents carefully before investing."
  }
}
